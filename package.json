{
  "name": "tina-alpaca",
  "version": "0.1.0",
  "description": "NextJS documentation starter with TinaCMS",
  "main": "index.js",
  "scripts": {
    "dev": "next",
    "debug": "NODE_OPTIONS='--inspect' next",
    "build": "next build",
    "start": "cross-env NODE_ENV=production next start",
    "format": "prettier --write \"**/*.{js,jsx,json,md}\"",
    "create-indices": "npx babel-node ./indices/createIndices.js"
  },
  "keywords": [
    "nextjs",
    "tinaCMS"
  ],
  "author": "Forestry.io",
  "license": "MIT",
  "dependencies": {
    "@tinacms/api-git": "^0.31.0",
    "@tinacms/git-client": "^0.34.0",
    "@zeit/next-sass": "^1.0.1",
    "algoliasearch": "^4.8.3",
    "axios": "^0.21.0",
    "cors": "^2.8.5",
    "dotenv": "^8.2.0",
    "express": "^4.17.1",
    "fast-glob": "^3.2.4",
    "file-loader": "^6.2.0",
    "final-form-calculate": "^1.3.2",
    "gray-matter": "^4.0.2",
    "markdown-toc": "^1.2.0",
    "moment": "^2.29.1",
    "next": "^10.0.3",
    "next-svgr": "^0.0.2",
    "next-tinacms-github": "^0.35.0",
    "next-tinacms-json": "^0.34.0",
    "next-tinacms-markdown": "^0.34.0",
    "node-sass": "^5.0.0",
    "raw-loader": "^4.0.2",
    "react": "^17.0.1",
    "react-dom": "^17.0.1",
    "react-instantsearch-dom": "^6.8.2",
    "react-markdown": "^5.0.3",
    "react-syntax-highlighter": "^15.4.3",
    "react-textarea-autosize": "^8.3.0",
    "react-tinacms-editor": "^0.35.0",
    "react-tinacms-github": "^0.35.0",
    "react-tinacms-inline": "^0.35.0",
    "remarkable": "^2.0.1",
    "slugify": "^1.4.6",
    "styled-components": "^5.2.1",
    "styled-normalize": "^8.0.7",
    "tinacms": "^0.34.0",
    "typeface-source-code-pro": "^1.1.13"
  },
  "devDependencies": {
    "@babel/core": "^7.12.10",
    "@babel/node": "^7.12.10",
    "@types/node": "^14.14.14",
    "babel-eslint": "^10.1.0",
    "babel-plugin-inline-react-svg": "^1.1.2",
    "babel-plugin-styled-components": "^1.12.0",
    "cross-env": "^7.0.3",
    "eslint": "^7.16.0",
    "eslint-config-prettier": "^7.1.0",
    "eslint-plugin-prettier": "^3.3.0",
    "eslint-plugin-react": "^7.21.5",
    "husky": "^4.3.6",
    "hygen-next-tinacms-github": "https://github.com/dwalkr/hygen-next-tinacms-github",
    "lint-staged": "^10.5.3",
    "prettier": "2.2.1"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "**/*.{js,jsx,json}": [
      "prettier --write"
    ]
  }
